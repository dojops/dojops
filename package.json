{
  "name": "dojops",
  "private": true,
  "description": "DojOps - AI Automation Engine",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dojops/dojops.git"
  },
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "dojops": "packages/cli/dist/index.js"
  },
  "scripts": {
    "dojops": "node packages/cli/dist/index.js",
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "turbo test:e2e",
    "test:smoke": "turbo test:smoke",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "publish-packages": "pnpm -r publish --access public --no-git-checks"
  },
  "lint-staged": {
    "*.{ts,mjs,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2.8.20",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.1"
  }
}
