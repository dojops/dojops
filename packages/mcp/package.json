{
  "name": "@dojops/mcp",
  "version": "1.2.2",
  "description": "MCP (Model Context Protocol) client and server for DojOps — connect external tool servers and expose DojOps as an MCP server",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dojops/dojops.git",
    "directory": "packages/mcp"
  },
  "keywords": [
    "devops",
    "mcp",
    "model-context-protocol",
    "tool-server",
    "agent",
    "claude-code",
    "copilot",
    "gemini"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "dojops-mcp": "dist/bin.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "test": "vitest run",
    "prepublishOnly": "test -f dist/index.js && test -f dist/index.d.ts"
  },
  "dependencies": {
    "@dojops/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^4.0.0"
  }
}
