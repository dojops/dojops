{
  "name": "@dojops/runtime",
  "version": "1.2.2",
  "description": "38 built-in .dops v2 skill runtime for DojOps",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dojops/dojops.git",
    "directory": "packages/runtime"
  },
  "keywords": [
    "devops",
    "dops",
    "skills",
    "runtime",
    "llm"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "skills"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "test": "vitest run",
    "prepublishOnly": "test -f dist/index.js && test -f dist/index.d.ts"
  },
  "dependencies": {
    "@dojops/core": "workspace:*",
    "@dojops/sdk": "workspace:*",
    "js-yaml": "^4.1.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9"
  }
}
